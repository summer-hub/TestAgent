{
  "name": "@ohos/stackblur",
  "version": "1.0.0",
  "description": "stackblur is an image blur library for OpenHarmony, implementing the StackBlur algorithm by Mario Klingemann. It applies high-quality blur effects to PixelMap images with a specified radius, offering two processing modes: a pure ArkTS implementation and a high-performance Native C implementation.",
  "main": "Index.ets",
  "author": "ohos_tpc",
  "license": "Apache-2.0",
  "dependencies": {
    "liblibrary.so": "file:./src/main/cpp/types/liblibrary"
  }
}